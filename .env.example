# Comment Copilot environment (SPEC Section 9). Copy to .env.local and fill in.
# App login is separate from YouTube API authorization (SPEC Section 3).

# Google OAuth (reuse the existing tehb-website OAuth client, add the
# youtube.force-ssl scope). SPEC Sections 3, 11.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth / Auth.js
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# App login allowlist, comma-separated (mirrors tehb-website ADMIN_EMAILS).
ALLOWED_EMAILS=josh@buywisemortgage.com,jeb@jebsmith.net

# Anthropic (server-side only, never shipped to the browser).
ANTHROPIC_API_KEY=

# Vercel Postgres (the integration sets POSTGRES_URL; DATABASE_URL also read).
DATABASE_URL=

# Symmetric key used to encrypt channel refresh tokens at rest (SPEC Section 3).
TOKEN_ENCRYPTION_KEY=
